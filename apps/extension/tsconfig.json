{
  "compilerOptions": {
    "composite": true,
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "jsx": "preserve",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "paths": {
      "@poe-sl/schema": ["../../packages/schema/src/index.ts"],
      "@poe-sl/trade-dom": ["../../packages/trade-dom/src/index.ts"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.vue", ".wxt/wxt.d.ts"]
}
