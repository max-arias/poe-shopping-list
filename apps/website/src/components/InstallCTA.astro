---
interface Props {
  browser?: 'Chrome' | 'Firefox';
  size?: 'lg' | 'sm';
  href?: string;
}
const { browser = 'Chrome', size = 'lg', href = '#' } = Astro.props;
const h = size === 'lg' ? 'h-[54px] text-[15px] px-5' : 'h-10 text-[13px] px-4';
---
<a
  href={href}
  class:list={[
    'inline-flex items-center gap-2.5 bg-gold border border-gold-edge text-gold-ink font-bold uppercase tracking-[0.4px] rounded-sm cursor-pointer no-underline',
    h,
  ]}
  style="box-shadow: inset 0 1px 0 rgba(255,255,255,0.2), 0 2px 0 rgba(0,0,0,0.25)"
>
  <span class="text-[18px]">⬇</span>
  Add to {browser}
</a>
