<!-- Tilted browser + extension sidebar mockup from prototype -->
<div class="w-full" style="perspective: 1400px">
  <div
    class="w-full border border-[#1a1610] rounded-sm overflow-hidden flex flex-col"
    style="
      aspect-ratio: 520/360;
      transform: rotateY(-14deg) rotateX(6deg) rotateZ(-2deg);
      transform-style: preserve-3d;
      box-shadow: 0 24px 60px rgba(26,20,12,0.35), 0 6px 16px rgba(26,20,12,0.25);
      background: #15110b;
    "
  >
    <!-- Fake browser chrome -->
    <div class="h-[22px] bg-[#d8d2c5] flex items-center gap-1 px-2 border-b border-[#9e9684] shrink-0">
      <div class="flex gap-1">
        <div class="w-2 h-2 rounded-full bg-[#e06b5e]"></div>
        <div class="w-2 h-2 rounded-full bg-[#e8b840]"></div>
        <div class="w-2 h-2 rounded-full bg-[#6ca86a]"></div>
      </div>
      <div class="ml-2 text-[9px] text-[#5a5040] font-mono">pathofexile.com/trade/search/Phrecia/abc123</div>
    </div>

    <!-- Split: trade page + sidebar -->
    <div class="flex flex-1 min-h-0">
      <!-- Trade page -->
      <div class="flex-1 bg-[#1f1912] p-2.5 flex flex-col gap-1.5" style="background-image: repeating-linear-gradient(0deg, rgba(255,255,255,0.015) 0 1px, transparent 1px 3px)">
        <div class="flex gap-1">
          <div class="h-4 w-[70px] bg-[#2a2218] rounded-[1px]"></div>
          <div class="h-4 w-[90px] bg-[#2a2218] rounded-[1px]"></div>
          <div class="flex-1"></div>
          <div class="h-4 w-10 bg-[#7a561a] rounded-[1px]"></div>
        </div>
        <div class="bg-[#15110b] p-1.5 rounded-[1px] flex flex-col gap-0.5">
          <div class="h-[10px] bg-[#231c10] rounded-[1px]"></div>
          <div class="h-[10px] bg-[#231c10] rounded-[1px]"></div>
          <div class="h-[10px] bg-[#231c10] rounded-[1px]"></div>
        </div>
        {[1,2,3,4,5].map(_ => (
          <div class="bg-[#15110b] px-2 py-1.5 rounded-[1px] flex items-center gap-1.5 border border-[#2a2218]">
            <div class="w-[18px] h-[18px] bg-[#3a3226] rounded-[1px] shrink-0"></div>
            <div class="flex-1 flex flex-col gap-0.5">
              <div class="h-[5px] w-3/4 bg-[#c29a54] rounded-[1px]"></div>
              <div class="h-[3px] w-1/2 bg-[#3a3226] rounded-[1px]"></div>
            </div>
            <div class="w-[42px] h-3 bg-[#7a561a] rounded-[1px] text-[8px] font-bold text-[#140e04] flex items-center justify-center font-mono">14ex</div>
          </div>
        ))}
      </div>

      <!-- Extension sidebar -->
      <div class="w-[175px] bg-bg border-l-2 border-[#1a1610] flex flex-col shrink-0">
        <!-- Sidebar chrome -->
        <div class="h-[22px] bg-chrome border-b border-stroke flex items-center px-1.5 gap-1 shrink-0">
          <div class="w-[9px] h-[9px] bg-gold border border-gold-edge rounded-[1px]"></div>
          <span class="text-[8px] font-bold text-ink">Shopping List</span>
          <div class="flex-1"></div>
          <span class="text-[7px] px-1 py-[1px] bg-gold-soft border border-gold-edge text-gold-ink-str rounded-[1px] font-bold tracking-[0.3px]">PHRECIA</span>
        </div>
        <!-- List name -->
        <div class="px-1.5 pt-1.5 pb-1 text-[8px] text-ink-muted uppercase font-bold tracking-[0.4px]">Boneshatter endgame · 8</div>
        <!-- Items -->
        {[
          ['Vaal Molten Shell', '14ex', true],
          ['Cyclopean Coil', '45ex', true],
          ['Abyssus corrupt', '12ex', false],
          ["Watcher's Eye", '80ex', false],
          ['Ashes of Stars', '110ex', false],
          ['Blessed Orb', '2c', true],
        ].map(([n, p, checked]) => (
          <div class="flex items-center gap-1 px-1.5 py-1 border-b border-stroke-soft">
            <div class:list={['w-2 h-2 border border-stroke rounded-[1px] shrink-0', checked ? 'bg-gold border-gold-edge' : '']}></div>
            <span class="flex-1 min-w-0 text-[8px] truncate text-ink">{n}</span>
            <span class="text-[8px] font-semibold text-gold-ink-str font-mono">{p}</span>
          </div>
        ))}
        <div class="flex-1"></div>
        <!-- Footer -->
        <div class="p-1.5 border-t border-stroke bg-section">
          <div class="h-[18px] bg-gold border border-gold-edge rounded-[1px] flex items-center justify-center text-[8px] font-bold text-gold-ink uppercase tracking-[0.4px]">
            Save This Search
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
