---
import InstallCTA from './InstallCTA.astro';
---
<footer class="bg-footer border-t border-stroke-soft">
  <div class="max-w-[1200px] mx-auto px-12 py-10 flex flex-col gap-8">
    <!-- CTA row -->
    <div class="flex flex-col items-center gap-4 text-center">
      <p class="text-[22px] font-bold tracking-[-0.3px] text-ink">Ready to stop copy-pasting trade links?</p>
      <p class="text-[13px] text-ink-muted">Free · open source · no account needed until you publish.</p>
      <div class="flex gap-2.5 flex-wrap justify-center">
        <InstallCTA browser="Chrome" />
        <InstallCTA browser="Firefox" />
      </div>
    </div>

    <!-- Nav + meta row -->
    <div class="flex items-center justify-between border-t border-stroke-soft pt-6 gap-6 flex-wrap">
      <div class="flex items-center gap-2">
        <div class="w-4 h-4 bg-gold border border-gold-edge rounded-[2px]"></div>
        <span class="font-semibold text-[13px] text-ink">PoE Shopping List</span>
      </div>
      <div class="flex gap-5 text-[12px] text-ink-muted">
        <a href="/" class="hover:text-ink no-underline">Builds</a>
        <a href="/how-it-works" class="hover:text-ink no-underline">How it works</a>
        <a href="/privacy" class="hover:text-ink no-underline">Privacy</a>
        <a href="https://github.com" target="_blank" rel="noopener noreferrer" class="hover:text-ink no-underline">GitHub ⇗</a>
      </div>
      <p class="text-[11px] text-ink-muted">
        Not affiliated with Grinding Gear Games.
      </p>
    </div>
  </div>
</footer>
