---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---
<Base title="Page Not Found">
  <div class="min-h-screen flex flex-col bg-bg">
    <Nav />
    <main class="flex-1 flex flex-col items-center justify-center gap-4 px-6 text-center">
      <p class="text-[80px] font-bold leading-none text-stroke-soft">404</p>
      <h1 class="text-2xl font-semibold text-text-primary">Page not found</h1>
      <p class="text-text-muted max-w-sm">The page you're looking for doesn't exist or has been moved.</p>
      <a href="/" class="mt-2 px-5 py-2 rounded-md bg-accent text-white text-sm font-medium hover:bg-accent/90 transition-colors">
        Back to home
      </a>
    </main>
    <Footer />
  </div>
</Base>
