---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import InstallCTA from '../components/InstallCTA.astro';
import BuildCard from '../components/BuildCard.astro';
import HeroMockup from '../components/HeroMockup.astro';
import { BUILDS } from '../data/builds';

const featured = BUILDS.slice(0, 3);
const all = BUILDS.slice(3);
---
<Base title="Build Shopping Lists for Path of Exile">
  <div class="min-h-screen flex flex-col bg-bg">
    <Nav activeTab="builds" />

    <!-- ── Hero ── -->
    <section class="bg-section border-b border-stroke-soft">
      <div class="max-w-[1200px] mx-auto px-12 py-[60px] flex gap-12 items-center">
        <!-- Copy -->
        <div class="flex-1">
          <p class="text-[11px] font-bold tracking-[1.2px] text-gold-ink-str uppercase mb-2.5">
            ⚔ Browser extension for Path of Exile
          </p>
          <h1 class="text-[38px] font-bold tracking-[-0.6px] leading-[1.1] mb-3.5 text-ink">
            Turn any build guide<br/>into a shopping list.
          </h1>
          <p class="text-[14px] text-ink-muted leading-relaxed mb-5 max-w-[480px]">
            Save trade searches from pathofexile.com/trade, group them into lists, and track
            price &amp; availability without leaving the page.
          </p>
          <div class="flex gap-2.5 flex-wrap">
            <InstallCTA browser="Chrome" />
            <InstallCTA browser="Firefox" />
          </div>
          <p class="mt-3.5 text-[11px] text-ink-muted">Free · open source · 12,400+ installs</p>
        </div>

        <!-- Mockup -->
        <div class="w-[520px] shrink-0 hidden lg:block">
          <HeroMockup />
        </div>
      </div>
    </section>

    <!-- ── Featured builds ── -->
    <section class="max-w-[1200px] mx-auto w-full px-12 py-9">
      <div class="flex items-baseline gap-3 mb-3.5">
        <h2 class="text-[20px] font-bold tracking-[-0.2px] text-ink">Featured builds</h2>
        <span class="text-[12px] text-ink-muted">Hand-picked by us</span>
        <div class="flex-1"></div>
        <a href="/" class="text-[12px] text-ink-muted border border-stroke-soft rounded-sm px-2.5 py-1 no-underline hover:border-stroke hover:text-ink">
          See all →
        </a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3.5">
        {featured.map(b => <BuildCard build={b} />)}
      </div>
    </section>

    <!-- ── All builds ── -->
    <section class="max-w-[1200px] mx-auto w-full px-12 pb-12">
      <div class="flex items-baseline gap-3 mb-3.5">
        <h2 class="text-[20px] font-bold tracking-[-0.2px] text-ink">All builds</h2>
        <span class="text-[12px] text-ink-muted" id="builds-count">Showing {all.length} of {BUILDS.length}</span>
      </div>

      <!-- Search + filters -->
      <div class="flex gap-3 mb-4 flex-wrap">
        <div class="h-9 flex items-center gap-2.5 px-3.5 bg-bg border border-stroke rounded-sm min-w-[280px]">
          <span class="text-ink-muted text-sm">🔍</span>
          <input
            id="search-input"
            type="search"
            placeholder="Search builds, classes, skills…"
            class="flex-1 bg-transparent text-[12px] text-ink outline-none border-0 placeholder:text-ink-muted"
          />
          <kbd class="text-[10px] px-1.5 py-[2px] bg-surface border border-stroke-soft rounded-sm text-ink-muted font-mono">⌘K</kbd>
        </div>
        <div class="flex gap-2 flex-wrap" id="game-filters">
          {(['All', 'PoE1', 'PoE2'] as const).map(g => (
            <button
              data-game={g}
              class:list={[
                'h-9 px-3 text-[11px] border rounded-sm cursor-pointer',
                g === 'All'
                  ? 'bg-gold-soft border-gold-edge text-gold-ink-str font-semibold'
                  : 'bg-bg border-stroke-soft text-ink',
              ]}
            >
              {g}
            </button>
          ))}
        </div>
      </div>

      <!-- Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3.5" id="builds-grid">
        {all.map(b => (
          <div
            class="build-card-wrapper"
            data-name={b.name.toLowerCase()}
            data-ascendancy={b.ascendancy.toLowerCase()}
            data-game={b.game}
          >
            <BuildCard build={b} />
          </div>
        ))}
      </div>

      <div id="no-results" class="hidden py-10 text-center text-[13px] text-ink-muted">
        No builds match your search.
      </div>
    </section>

    <Footer />
  </div>
</Base>

<script>
  const input = document.getElementById('search-input') as HTMLInputElement;
  const grid = document.getElementById('builds-grid');
  const noResults = document.getElementById('no-results');
  const count = document.getElementById('builds-count');
  const gameFilters = document.querySelectorAll<HTMLButtonElement>('#game-filters button');
  let activeGame = 'All';

  function updateFilters() {
    const q = input.value.toLowerCase().trim();
    const cards = grid?.querySelectorAll<HTMLElement>('.build-card-wrapper') ?? [];
    let visible = 0;
    cards.forEach(card => {
      const name = card.dataset.name ?? '';
      const asc = card.dataset.ascendancy ?? '';
      const game = card.dataset.game ?? '';
      const matchText = !q || name.includes(q) || asc.includes(q);
      const matchGame = activeGame === 'All' || game === activeGame;
      const show = matchText && matchGame;
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    });
    if (noResults) noResults.classList.toggle('hidden', visible > 0);
    if (count) count.textContent = `Showing ${visible} of ${cards.length}`;
  }

  input?.addEventListener('input', updateFilters);

  gameFilters.forEach(btn => {
    btn.addEventListener('click', () => {
      activeGame = btn.dataset.game ?? 'All';
      gameFilters.forEach(b => {
        const active = b.dataset.game === activeGame;
        b.className = active
          ? 'h-9 px-3 text-[11px] border rounded-sm cursor-pointer bg-gold-soft border-gold-edge text-gold-ink-str font-semibold'
          : 'h-9 px-3 text-[11px] border rounded-sm cursor-pointer bg-bg border-stroke-soft text-ink';
      });
      updateFilters();
    });
  });

  // ⌘K focus search
  document.addEventListener('keydown', e => {
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      input?.focus();
    }
  });
</script>
