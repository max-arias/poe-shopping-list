---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}
const { title, description = 'Save trade searches from pathofexile.com/trade and track your build shopping list.' } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — PoE Shopping List</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <!-- Prevent theme flash -->
    <script is:inline>
      (function () {
        var t = localStorage.getItem('poe-sl-theme') || 'light';
        document.documentElement.setAttribute('data-theme', t);
      })();
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
